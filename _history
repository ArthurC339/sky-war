. . . . .\n`, SpriteKind.Player)\n\n// ================= POSIÇÃO =================\nplayer1.setPosition(20, 60)\nplayer2.setPosition(140, 60)\n\ncontroller.player1.moveSprite(player1, 100, 100)\ncontroller.player2.moveSprite(player2, 100, 100)\n\n// ================= VIDAS =================\ninfo.player1.setLife(3)\ninfo.player2.setLife(3)\n\n// ================= BLOQUEIO =================\nlet travado = false\n\nfunction travarJogo() {\n    travado = true\n    controller.player1.moveSprite(player1, 0, 0)\n    controller.player2.moveSprite(player2, 0, 0)\n}\n\n// ================= DESBLOQUEIO =================\nfunction destravarJogo() {\n    controller.player1.moveSprite(player1, 100, 100)\n    controller.player2.moveSprite(player2, 100, 100)\n    travado = false\n}\n\n// ================= RESET =================\nfunction resetar() {\n    player1.setPosition(20, 60)\n    player2.setPosition(140, 60)\n}\n\n// ================= DANO COM PAUSA =================\nfunction aplicarDano(alvo: Sprite) {\n\n    travarJogo()\n\n    if (alvo == player1) {\n        info.player1.changeLifeBy(-1)\n\n        game.showLongText(\"Player 1 perdeu 1 vida\", DialogLayout.Center)\n\n        pause(3000)\n\n        if (info.player1.life() <= 0) {\n            game.over(false, effects.dissolve)\n        } else {\n            resetar()\n            destravarJogo()\n        }\n\n    } else if (alvo == player2) {\n        info.player2.changeLifeBy(-1)\n\n        game.showLongText(\"Player 2 perdeu 1 vida\", DialogLayout.Center)\n\n        pause(3000)\n\n        if (info.player2.life() <= 0) {\n            game.over(true, effects.confetti)\n        } else {\n            resetar()\n            destravarJogo()\n        }\n    }\n}\n\n// ================= COLISÃO =================\nsprites.onOverlap(SpriteKind.ProjectileP1, SpriteKind.Player, function (proj, alvo) {\n    if (!travado && alvo == player2) {\n        proj.destroy()\n        aplicarDano(alvo)\n    }\n})\n\nsprites.onOverlap(SpriteKind.ProjectileP2, SpriteKind.Player, function (proj, alvo) {\n    if (!travado && alvo == player1) {\n        proj.destroy()\n        aplicarDano(alvo)\n    }\n})\n\n// ================= TIROS =================\ncontroller.player1.onButtonEvent(ControllerButton.A, ControllerButtonEvent.Pressed, function () {\n    if (!travado) {\n        let tiro = sprites.createProjectileFromSprite(img`\n            . . . . . 2 . . .\n            . . . 2 5 2 . . .\n            . . . . 1 . . . .\n        `, player1, 0, 80)\n        tiro.setKind(SpriteKind.ProjectileP1)\n    }\n})\n\ncontroller.player2.onButtonEvent(ControllerButton.B, ControllerButtonEvent.Pressed, function () {\n    if (!travado) {\n        let tiro = sprites.createProjectileFromSprite(img`\n            . . . . . 4 . . .\n            . . . 4 4 4 . . .\n            . . . . 1 . . . .\n        `, player2, 0, 80)\n        tiro.setKind(SpriteKind.ProjectileP2)\n    }\n})","README.md":" ","assets.json":"","images.g.jres":"{\n    \"image1\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"displayName\": \"myImage\"\n    },\n    \"anim1\": {\n        \"namespace\": \"myAnimations\",\n        \"id\": \"anim1\",\n        \"mimeType\": \"application/mkcd-animation\",\n        \"data\": \"\",\n        \"displayName\": \"myAnim\"\n    },\n    \"anim2\": {\n        \"namespace\": \"myAnimations\",\n        \"id\": \"anim2\",\n        \"mimeType\": \"application/mkcd-animation\",\n        \"data\": \"\",\n        \"displayName\": \"myAnim0\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myImages\"\n    }\n}","images.g.ts":"","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA